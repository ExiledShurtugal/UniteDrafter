@page "/"
@rendermode InteractiveServer

<PageTitle>UniteDrafter</PageTitle>

<div class="draft-page">
    <header class="draft-header">
        <div>
            <p class="eyebrow">MVP Draft Board</p>
            <h1>UniteDrafter</h1>
            <p class="subtitle">A basic single-page layout for allies, enemies, search, and matchup info.</p>
        </div>
    </header>

    <div class="draft-board">
        <section class="team-column ally-column">
            <div class="column-header">
                <h2>Your Team</h2>
                <p>Five ally slots</p>
            </div>

            <div class="slot-list">
                @for (var index = 1; index <= SlotCount; index++)
                {
                    var slot = new DraftSlotRef(TeamSide.Ally, index);

                    <button
                        type="button"
                        class="@GetSlotClass(slot)"
                        aria-pressed="@IsActiveSlot(slot)"
                        @onclick="() => SelectSlot(slot)">
                        <span class="slot-number">@index</span>
                        <span class="slot-content">
                            <strong>Empty ally slot</strong>
                            <span>@GetSlotHint(slot)</span>
                        </span>
                    </button>
                }
            </div>
        </section>

        <section class="center-column">
            <div class="panel">
                <h2>Search</h2>
                <p class="selection-summary">@GetSelectionSummary()</p>
                <input
                    class="search-input"
                    type="text"
                    placeholder="Search Pokemon name"
                    aria-label="Search Pokemon name" />
                <p class="search-hint">Search wiring comes next. For now, click a slot to choose where the next pick will go.</p>
            </div>

            <div class="panel">
                <h2>Pokemon Info</h2>
                <p>@GetInfoText()</p>

                <div class="info-placeholder">
                    <div class="info-box">Portrait</div>
                    <div class="info-details">
                        <p>Name</p>
                        <p>Role</p>
                        <p>Notes</p>
                    </div>
                </div>
            </div>

            <div class="panel">
                <h2>Matchups</h2>

                <div class="matchup-columns">
                    <div class="matchup-box">
                        <h3>Best Against</h3>
                        <p>No data yet.</p>
                    </div>

                    <div class="matchup-box">
                        <h3>Worst Against</h3>
                        <p>No data yet.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="team-column enemy-column">
            <div class="column-header">
                <h2>Opponent Team</h2>
                <p>Five enemy slots</p>
            </div>

            <div class="slot-list">
                @for (var index = 1; index <= SlotCount; index++)
                {
                    var slot = new DraftSlotRef(TeamSide.Enemy, index);

                    <button
                        type="button"
                        class="@GetSlotClass(slot)"
                        aria-pressed="@IsActiveSlot(slot)"
                        @onclick="() => SelectSlot(slot)">
                        <span class="slot-number">@index</span>
                        <span class="slot-content">
                            <strong>Empty enemy slot</strong>
                            <span>@GetSlotHint(slot)</span>
                        </span>
                    </button>
                }
            </div>
        </section>
    </div>
</div>

@code {
    private const int SlotCount = 5;

    private DraftSlotRef activeSlot = new(TeamSide.Ally, 1);

    private void SelectSlot(DraftSlotRef slot)
    {
        activeSlot = slot;
    }

    private bool IsActiveSlot(DraftSlotRef slot) => slot == activeSlot;

    private string GetSlotClass(DraftSlotRef slot)
    {
        var classes = "draft-slot";

        if (slot.Team == TeamSide.Enemy)
        {
            classes += " opponent-slot";
        }

        if (IsActiveSlot(slot))
        {
            classes += " active-slot";
        }

        return classes;
    }

    private string GetSlotHint(DraftSlotRef slot) =>
        IsActiveSlot(slot) ? "Selected for the next pick" : "Click to target this slot";

    private string GetSelectionSummary() =>
        $"Selected slot: {GetTeamLabel(activeSlot.Team)} #{activeSlot.Index}";

    private string GetInfoText() =>
        $"No Pokemon selected yet. {GetTeamLabel(activeSlot.Team)} #{activeSlot.Index} is ready for your next pick.";

    private static string GetTeamLabel(TeamSide team) =>
        team == TeamSide.Ally ? "Your Team" : "Opponent Team";

    private enum TeamSide
    {
        Ally,
        Enemy
    }

    private readonly record struct DraftSlotRef(TeamSide Team, int Index);
}
