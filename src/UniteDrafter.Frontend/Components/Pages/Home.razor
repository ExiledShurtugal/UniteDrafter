@page "/"
@rendermode InteractiveServer
@using UniteDrafter.Data
@using UniteDrafter.Services

<PageTitle>UniteDrafter</PageTitle>

<div class="draft-page">
    <header class="draft-header">
        <div>
            <p class="eyebrow">MVP Draft Board</p>
            <h1>UniteDrafter</h1>
            <p class="subtitle">Search real Pokemon from the database and assign them to ally or enemy slots.</p>
        </div>
    </header>

    <div class="draft-board">
        <section class="team-column ally-column">
            <div class="column-header">
                <h2>Your Team</h2>
                <p>Five ally slots</p>
            </div>

            <div class="slot-list">
                @for (var index = 1; index <= SlotCount; index++)
                {
                    var slot = new DraftSlotRef(TeamSide.Ally, index);

                    <button
                        type="button"
                        class="@GetSlotClass(slot)"
                        aria-pressed="@IsActiveSlot(slot)"
                        @onclick="() => SelectSlot(slot)">
                        <span class="slot-number">@index</span>
                        <span class="slot-content">
                            <strong>@GetSlotTitle(slot)</strong>
                            <span>@GetSlotHint(slot)</span>
                        </span>
                    </button>
                }
            </div>
        </section>

        <section class="center-column">
            <div class="panel">
                <h2>Available Pokemon</h2>
                <p class="selection-summary">@GetSelectionSummary()</p>
                <input
                    class="search-input"
                    type="text"
                    value="@SearchTerm"
                    placeholder="Search Pokemon name"
                    aria-label="Search Pokemon name"
                    @oninput="HandleSearchInput" />

                <div class="draft-actions">
                    <button type="button" class="draft-action secondary-action" @onclick="ClearActiveSlot">Clear slot</button>
                    <button type="button" class="draft-action danger-action" @onclick="ResetDraft">Reset draft</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(SearchMessage))
                {
                    <p class="search-hint">@SearchMessage</p>
                }

                @if (!string.IsNullOrWhiteSpace(AvailablePokemonMessage))
                {
                    <p class="available-pokemon-summary">@AvailablePokemonMessage</p>
                }

                @if (AvailablePokemon.Count > 0)
                {
                    <div class="available-pokemon-list" role="list" aria-label="Available Pokemon">
                        @foreach (var pokemon in AvailablePokemon)
                        {
                            <button
                                type="button"
                                class="available-pokemon-row"
                                @onclick="() => AssignPokemon(pokemon.PokemonName)">
                                <strong>@pokemon.PokemonName</strong>
                                <span>@GetSearchResultSubtitle(pokemon)</span>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="panel">
                <h2>Matchups</h2>

                <div class="matchup-columns">
                    <div class="matchup-box">
                        <h3>Best Against</h3>

                        @if (ActivePokemon is null || ActivePokemon.BestAgainst.Count == 0)
                        {
                            <p>@GetMatchupEmptyText()</p>
                        }
                        else
                        {
                            <div class="matchup-list">
                                @foreach (var matchup in ActivePokemon.BestAgainst)
                                {
                                    <div class="matchup-row">
                                        <span>@matchup.OpponentName</span>
                                        <strong>@FormatWinRate(matchup.WinRate)</strong>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="matchup-box">
                        <h3>Worst Against</h3>

                        @if (ActivePokemon is null || ActivePokemon.WorstAgainst.Count == 0)
                        {
                            <p>@GetMatchupEmptyText()</p>
                        }
                        else
                        {
                            <div class="matchup-list">
                                @foreach (var matchup in ActivePokemon.WorstAgainst)
                                {
                                    <div class="matchup-row">
                                        <span>@matchup.OpponentName</span>
                                        <strong>@FormatWinRate(matchup.WinRate)</strong>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </section>

        <section class="team-column enemy-column">
            <div class="column-header">
                <h2>Opponent Team</h2>
                <p>Five enemy slots</p>
            </div>

            <div class="slot-list">
                @for (var index = 1; index <= SlotCount; index++)
                {
                    var slot = new DraftSlotRef(TeamSide.Enemy, index);

                    <button
                        type="button"
                        class="@GetSlotClass(slot)"
                        aria-pressed="@IsActiveSlot(slot)"
                        @onclick="() => SelectSlot(slot)">
                        <span class="slot-number">@index</span>
                        <span class="slot-content">
                            <strong>@GetSlotTitle(slot)</strong>
                            <span>@GetSlotHint(slot)</span>
                        </span>
                    </button>
                }
            </div>
        </section>
    </div>
</div>
